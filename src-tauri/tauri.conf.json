{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sp3 Lock",
  "version": "1.0.0",
  "identifier": "com.sp3.lock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sp3 Lock",
        "width": 420,
        "height": 820,
        "minWidth": 380,
        "minHeight": 680,
        "maxWidth": 560,
        "center": true,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "copyright": "© 2026 sp3 — GPL-3.0",
    "category": "Utility",
    "shortDescription": "Offline password manager",
    "longDescription": "sp3 Lock is a 100% offline, portable password manager with military-grade AES-256-GCM encryption. No account required — just a 16-digit access number.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["German", "English"],
        "installMode": "both",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
